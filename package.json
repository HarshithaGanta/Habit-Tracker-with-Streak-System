{
  "name": "habit-tracker-with-streak-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-all": "npm install --prefix client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "uvicorn app.main:app --reload --host 0.0.0.0 --port 5000 --app-dir server",
    "build": "npm run build --prefix client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
